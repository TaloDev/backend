{
  "compilerOptions": {
    "declaration": true,
    "esModuleInterop": true,
    "lib": ["ESNext", "ES2024.Collection"],
    "module": "nodenext",
    "moduleDetection": "force",
    "moduleResolution": "nodenext",
    "noImplicitOverride": true,
    "outDir": "dist",
    "skipLibCheck": true,
    "strict": true,
    "target": "es2024",
    "types": ["vitest/globals", "./src/global.d.ts"]
  }
}
